# Dependencies — installed fresh by `npm install` in CI and locally;
# never commit this, it's enormous and machine/platform-specific.
node_modules/

# Build output — regenerated by the GitHub Actions workflow on every
# deploy. Committing dist/ would mean stale built files sitting in the
# repo, which could get confused for source or cause merge conflicts
# that have nothing to do with actual code changes.
dist/

# Editor/OS noise
.DS_Store
*.log
.vscode/
.idea/

# Vite's local cache
.vite/
